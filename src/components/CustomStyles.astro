---
import '@fontsource-variable/inter';

// 'DM Sans'
// Nunito
// Dosis
// Outfit
// Roboto
// Literata
// 'IBM Plex Sans'
// Karla
// Poppins
// 'Fira Sans'
// 'Libre Franklin'
// Inconsolata
// Raleway
// Oswald
// 'Space Grotesk'
// Urbanist
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(30 99 182);
    --aw-color-secondary: rgb(23 78 145);
    --aw-color-accent: rgb(46 139 87);

    --aw-color-text-heading: rgb(17 20 24);
    --aw-color-text-default: rgb(37 42 46);
    --aw-color-text-muted: rgb(94 104 106 / 88%);
    --aw-color-text-page: rgb(17 20 24);
    --aw-color-bg-page: rgb(247 248 246);

    --aw-color-bg-page-dark: rgb(5 6 7);

    ::selection {
      background-color: rgb(220 236 244);
      color: rgb(17 20 24);
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(42 123 200);
    --aw-color-secondary: rgb(126 200 227);
    --aw-color-accent: rgb(126 200 227);

    --aw-color-text-heading: rgb(242 244 243);
    --aw-color-text-default: rgb(230 235 234);
    --aw-color-text-muted: rgb(167 176 178 / 84%);
    --aw-color-text-page: rgb(242 244 243);
    --aw-color-bg-page: rgb(5 6 7);

    ::selection {
      background-color: rgb(27 59 74);
      color: rgb(242 244 243);
    }
  }
</style>
