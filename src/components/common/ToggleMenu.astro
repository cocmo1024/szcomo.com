---
export interface Props {
  label?: string;
  class?: string;
}

const {
  label = 'Toggle Menu',
  class: className = 'flex h-10 w-10 flex-col items-center justify-center rounded-full cursor-pointer group',
} = Astro.props;
---

<button type="button" class={className} aria-label={label} data-aw-toggle-menu>
  <span class="sr-only">{label}</span>
  <slot>
    <span
      aria-hidden="true"
      class="my-1 h-px w-5 rounded-full bg-black opacity-80 transition duration-200 ease-out dark:bg-white group-[.expanded]:translate-y-2 group-[.expanded]:rotate-45"
    ></span>
    <span
      aria-hidden="true"
      class="my-1 h-px w-5 rounded-full bg-black opacity-80 transition duration-200 ease-out dark:bg-white group-[.expanded]:opacity-0"
    ></span>
    <span
      aria-hidden="true"
      class="my-1 h-px w-5 rounded-full bg-black opacity-80 transition duration-200 ease-out dark:bg-white group-[.expanded]:-translate-y-2 group-[.expanded]:-rotate-45"
    ></span>
  </slot>
</button>
