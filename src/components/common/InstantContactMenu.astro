---
import { Icon } from 'astro-icon/components';

const phone = '8615301541312';
const greeting =
  'Hello, I would like to discuss a Como Precision project. I can send drawings, CAD files, quantity, material targets, and requirements.';
const encodedGreeting = encodeURIComponent(greeting);

const whatsappHref = `https://wa.me/${phone}?text=${encodedGreeting}`;
---

<a
  class="inline-flex items-center rounded-lg p-2.5 text-sm text-muted transition hover:bg-gray-100 hover:text-emerald-600 focus:outline-none focus:ring-4 focus:ring-gray-200 dark:text-gray-400 dark:hover:bg-gray-700 dark:hover:text-emerald-400 dark:focus:ring-gray-700"
  href={whatsappHref}
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Contact Como Precision via WhatsApp"
  title="Contact Como Precision via WhatsApp"
  data-aw-instant-contact-link
  data-aw-contact-channel="whatsapp"
>
  <Icon name="tabler:brand-whatsapp" class="h-5 w-5" />
  <span class="sr-only">Contact Como Precision via WhatsApp</span>
</a>
