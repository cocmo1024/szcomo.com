---
import { UI } from 'astrowind:config';

// TODO: This code is temporary
---

<script is:inline data-default-theme={UI.theme || 'system'}>
  const defaultTheme = document.currentScript?.dataset.defaultTheme || 'system';

  function getStoredTheme() {
    try {
      return localStorage.theme || '';
    } catch {
      return '';
    }
  }

  function hasStoredTheme() {
    try {
      return 'theme' in localStorage;
    } catch {
      return false;
    }
  }

  function applyTheme(theme) {
    if (theme === 'dark') {
      document.documentElement.classList.add('dark');
    } else {
      document.documentElement.classList.remove('dark');
    }
    const matches = document.querySelectorAll('[data-aw-toggle-color-scheme] > input');

    if (matches && matches.length) {
      matches.forEach((elem) => {
        elem.checked = theme !== 'dark';
      });
    }
  }

  const storedTheme = getStoredTheme();

  if ((defaultTheme && defaultTheme.endsWith(':only')) || (!storedTheme && defaultTheme !== 'system')) {
    applyTheme(defaultTheme.replace(':only', ''));
  } else if (
    storedTheme === 'dark' ||
    (!hasStoredTheme() && window.matchMedia('(prefers-color-scheme: dark)').matches)
  ) {
    applyTheme('dark');
  } else {
    applyTheme('light');
  }
</script>
