---
import { SITE } from 'astrowind:config';
import { getHomePermalink } from '~/utils/permalinks';

interface Link {
  text?: string;
  href?: string;
  ariaLabel?: string;
  icon?: string;
}

interface Links {
  title?: string;
  links: Array<Link>;
}

export interface Props {
  links: Array<Links>;
  secondaryLinks: Array<Link>;
  socialLinks: Array<Link>;
  footNote?: string;
  theme?: string;
}

const { secondaryLinks = [], links = [], footNote = '', theme = 'light' } = Astro.props;
---

<footer class:list={[{ dark: theme === 'dark' }, 'relative not-prose']}>
  <div class="dark:bg-dark absolute inset-0 pointer-events-none" aria-hidden="true"></div>
  <div
    class="relative mx-auto max-w-6xl px-4 py-10 text-slate-700 dark:text-slate-300 sm:px-6 lg:py-12 intersect-once intersect-quarter intersect-no-queue"
  >
    <div class="grid gap-10 lg:grid-cols-[minmax(0,1.05fr)_minmax(0,2fr)] lg:gap-14">
      <div class="max-w-sm">
        <a
          class="inline-block text-lg font-bold tracking-tight text-slate-900 dark:text-white"
          href={getHomePermalink()}>{SITE?.name}</a
        >
        <p class="mt-4 text-sm leading-6 text-muted dark:text-slate-400">
          Industrial 3D printing, titanium and copper additive manufacturing, metal powders, and precision ceramic
          machining.
        </p>
        <a
          class="mt-5 inline-flex text-sm font-medium text-slate-800 underline underline-offset-4 hover:text-primary dark:text-slate-200 dark:hover:text-cyan-200"
          href="mailto:info@szcomo.com"
          aria-label="Email project drawings and requirements to info@szcomo.com"
        >
          info@szcomo.com
        </a>
        <div class="mt-5 flex flex-wrap gap-x-3 gap-y-2 text-sm text-muted">
          {
            secondaryLinks.map(({ text, href }, index) => (
              <>
                {index !== 0 ? <span class="text-slate-300 dark:text-slate-700">/</span> : ''}
                <a
                  class="text-muted transition duration-150 ease-in-out hover:text-gray-700 hover:underline dark:text-gray-400"
                  href={href}
                  set:html={text}
                />
              </>
            ))
          }
        </div>
      </div>
      <nav class="grid grid-cols-2 gap-x-8 gap-y-8 sm:grid-cols-4 lg:gap-x-10" aria-label="Footer navigation">
        {
          links.map(({ title, links }) => (
            <div>
              <div class="mb-3 text-sm font-semibold text-slate-900 dark:text-slate-100">{title}</div>
              {links && Array.isArray(links) && links.length > 0 && (
                <ul class="space-y-2.5 text-sm leading-6">
                  {links.map(({ text, href, ariaLabel }) => (
                    <li>
                      <a
                        class="text-muted transition duration-150 ease-in-out hover:text-gray-700 hover:underline dark:text-gray-400 dark:hover:text-slate-200"
                        href={href}
                        aria-label={ariaLabel}
                      >
                        <Fragment set:html={text} />
                      </a>
                    </li>
                  ))}
                </ul>
              )}
            </div>
          ))
        }
      </nav>
    </div>
    <div class="mt-10 flex flex-col gap-4 text-sm sm:flex-row sm:items-center sm:justify-between">
      <div class="text-muted dark:text-slate-400">
        <Fragment set:html={footNote} />
      </div>
    </div>
  </div>
</footer>
