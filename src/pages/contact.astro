---
import Layout from '~/layouts/PageLayout.astro';
import { createBreadcrumbSchema } from '~/utils/structured-data';

const email = 'info@szcomo.com';
const emailHref = `mailto:${email}`;

const metadata = {
  title: 'Contact Como Precision',
  description:
    'Contact Como Precision for industrial 3D printing, titanium and copper additive manufacturing, metal powders, precision ceramic machining, and project review.',
  openGraph: {
    images: [
      {
        url: '~/assets/images/como/og-como.webp',
        width: 1200,
        height: 630,
      },
    ],
    type: 'website',
  },
  structuredData: createBreadcrumbSchema([
    { name: 'Home', item: '/' },
    { name: 'Contact', item: '/contact/' },
  ]),
};
---

<Layout metadata={metadata}>
  <section class="border-b border-slate-200/80 py-16 dark:border-slate-800 md:py-24">
    <div class="mx-auto max-w-5xl px-4 sm:px-6">
      <p class="text-sm font-semibold uppercase tracking-[0.22em] text-slate-500 dark:text-slate-400">Contact</p>
      <h1 class="mt-4 max-w-3xl text-5xl font-semibold leading-tight tracking-normal text-slate-950 dark:text-white">
        Send drawings, material targets, quantities, and acceptance requirements.
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-600 dark:text-slate-300">
        We route inquiries across metal powders, titanium AM, copper AM, precision ceramics, finishing, and inspection
        support.
      </p>
      <a class="btn-primary mt-8" href={emailHref}>Email {email}</a>
    </div>
  </section>

  <section class="py-12 md:py-16">
    <div class="mx-auto grid max-w-5xl gap-8 px-4 sm:px-6 md:grid-cols-3">
      <div class="border-t border-slate-200 pt-5 dark:border-slate-800">
        <h2 class="text-lg font-semibold text-slate-950 dark:text-white">Project basics</h2>
        <p class="mt-3 text-sm leading-6 text-slate-600 dark:text-slate-400">
          Send drawings, STEP files, material, quantity, delivery target, and any critical performance requirements.
        </p>
      </div>
      <div class="border-t border-slate-200 pt-5 dark:border-slate-800">
        <h2 class="text-lg font-semibold text-slate-950 dark:text-white">Technical details</h2>
        <p class="mt-3 text-sm leading-6 text-slate-600 dark:text-slate-400">
          Add surface finish, tolerance, heat treatment, conductivity, density, or inspection needs when they matter.
        </p>
      </div>
      <div class="border-t border-slate-200 pt-5 dark:border-slate-800">
        <h2 class="text-lg font-semibold text-slate-950 dark:text-white">Response path</h2>
        <p class="mt-3 text-sm leading-6 text-slate-600 dark:text-slate-400">
          We reply by email with next-step questions, platform routing, feasibility notes, or quotation follow-up.
        </p>
      </div>
    </div>
  </section>
</Layout>
